#!/bin/sh

# Ensure tailwindcss binary exists
if [ ! -f "./tailwindcss" ]; then
    echo "⬇️  Downloading standalone Tailwind CLI..."
    OS=$(uname -s | tr '[:upper:]' '[:lower:]')
    ARCH=$(uname -m)
    
    if [ "$ARCH" = "x86_64" ]; then
        ARCH="x64"
    elif [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then
        ARCH="arm64"
    fi
    
    # Map darwin to macos
    if [ "$OS" = "darwin" ]; then
        OS="macos"
    fi
    
    wget -qO tailwindcss "https://github.com/tailwindlabs/tailwindcss/releases/latest/download/tailwindcss-${OS}-${ARCH}"
    chmod +x tailwindcss
fi

echo "🖌️ Building Tailwind CSS..."
./tailwindcss -i ./static/src/tailwind.css -o ./static/dist/tailwind.css --minify

# Add the compiled CSS to the git index so it gets committed
git add static/dist/tailwind.css
echo "✅ Tailwind CSS compiled and staged!"
